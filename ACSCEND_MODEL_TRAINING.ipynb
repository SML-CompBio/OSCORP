      "source": [
        "def plot_confusion_matrix(predictions, model_name, true_label=y_test):\n",
        "\n",
        "    cm = ConfusionMatrixDisplay.from_predictions(true_label, predictions, display_labels=['hESC', 'hMSC', 'hUSC','iPSC'])\n",
        "\n",
        "    filename = \"Conf_Mat_\"+model_name_abbrs[model_name]+\".png\"\n",
        "    cm.figure_.savefig(PATH+'Results/ConfusionMatrix_Plots/'+filename, dpi=600)\n",
        "    plt.close()"
      ]
    },
