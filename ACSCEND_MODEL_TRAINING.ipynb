        "X_train, y_train = train.iloc[:, :-1], train['numeric_label']\n",
        "X_test, y_test = test.iloc[:, :-1], test['numeric_label']\n",
        "\n",
        "print(X_train.shape, y_train.shape, X_test.shape, y_test.shape)"
      ]
