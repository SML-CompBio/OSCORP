        "# precision recall curve\n",
        "\n",
        "def plot_precision_recall(predicted_label, model_name, test_label=y_test_binarize):\n",
        "    precision = dict()\n",
        "    recall = dict()\n",
        "\n",
        "    for i in range(n_classes):\n",
        "        precision[i], recall[i], _ = precision_recall_curve(test_label[:, i],\n",
        "                                                            predicted_label[:, i])\n",
        "        plt.plot(recall[i], precision[i], lw=2, label='{}'.format(label_encoder.classes_[i]))\n",
        "\n",
        "    plt.xlabel(\"Recall\")\n",
        "    plt.ylabel(\"Precision\")\n",
        "    plt.legend(loc=\"best\")\n",
        "    plt.title(\"Precision vs. Recall curve for \"+model_name)\n",
        "\n",
        "\n",
        "    filename = \"Prec_Rec_\"+model_name_abbrs[model_name]+\".png\"\n",
        "    plt.savefig(PATH+'/Results/Plots_Precision_Recall_RoC/'+filename, dpi=600)\n",
        "    plt.close()\n",
        "\n",
        "    # plt.show()"
      ]
