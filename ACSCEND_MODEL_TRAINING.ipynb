      "source": [
        "# roc curve\n",
        "\n",
        "def plot_roc_curve(predicted_label, model_name, test_label=y_test_binarize):\n",
        "    fpr = dict()\n",
        "    tpr = dict()\n",
        "    roc_auc = dict()\n",
        "\n",
        "    for i in range(n_classes):\n",
        "        fpr[i], tpr[i], _ = roc_curve(test_label[:, i],\n",
        "                                    predicted_label[:, i])\n",
        "        roc_auc[i] = auc(fpr[i], tpr[i])\n",
        "\n",
        "        print(\"for \"+model_name+\" ,class: \"+str(i)+\" AUC: \"+str( roc_auc[i]))\n",
        "        plt.plot(fpr[i], tpr[i], lw=2, label='{0} (AUC = {1:0.3f})'.format(label_encoder.classes_[i], roc_auc[i]))\n",
        "\n",
        "\n",
        "    plt.xlabel(\"False Positive Rate\")\n",
        "    plt.ylabel(\"True Positive Rate\")\n",
        "    plt.legend(loc=\"best\")\n",
        "    plt.title(\"ROC curve for \"+model_name)\n",
        "\n",
        "    filename = \"RoC_\"+model_name_abbrs[model_name]+\".png\"\n",
        "    plt.savefig(PATH+'Results/Plots_Precision_Recall_RoC/'+filename, dpi=600)\n",
        "    plt.close()\n",
        "\n",
        "    # plt.show()"
      ]
    },
