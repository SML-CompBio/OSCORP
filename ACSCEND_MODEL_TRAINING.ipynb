      "source": [
        "X = df.iloc[:, :-1]\n",
        "y = df['numeric_label']\n",
        "n_classes = len(set(y))\n",
        "Y = label_binarize(df['numeric_label'], classes=[*range(n_classes)])\n",
        "\n",
        "X_train_binarize, X_test_binarize, y_train_binarize, y_test_binarize = train_test_split(df,\n",
        "                                                                                        Y,\n",
        "                                                                                        test_size = 0.3,\n",
        "                                                                                        random_state = 42)"
      ]
